#!/usr/bin/env bash
# search - Run gh search repos with correct field names and sensible defaults.
#
# Usage: search <query> [--limit N] [--sort stars|updated|forks|best-match]
#                       [--language LANG] [--topic TOPIC] [--stars RANGE]
#                       [--updated RANGE]
#
# Output: JSON array of repos with all useful fields.
# Errors go to stderr; stdout is always valid JSON (or empty on failure).

set -euo pipefail

LIMIT=10
SORT="stars"
LANGUAGE=""
TOPIC=""
STARS=""
UPDATED=""
QUERY=""

# JSON fields that actually exist on gh search repos
JSON_FIELDS="name,fullName,owner,description,stargazersCount,forksCount,openIssuesCount,language,license,updatedAt,pushedAt,url,isArchived,isFork"

usage() {
  echo "Usage: search <query> [--limit N] [--sort stars|updated|forks|best-match]" >&2
  echo "              [--language LANG] [--topic TOPIC] [--stars RANGE] [--updated RANGE]" >&2
  exit 1
}

# Parse args
while [[ $# -gt 0 ]]; do
  case "$1" in
    --limit)   LIMIT="$2"; shift 2 ;;
    --sort)    SORT="$2"; shift 2 ;;
    --language) LANGUAGE="$2"; shift 2 ;;
    --topic)   TOPIC="$2"; shift 2 ;;
    --stars)   STARS="$2"; shift 2 ;;
    --updated) UPDATED="$2"; shift 2 ;;
    --help|-h) usage ;;
    -*)        echo "Unknown flag: $1" >&2; usage ;;
    *)
      if [[ -z "$QUERY" ]]; then
        QUERY="$1"
      else
        QUERY="$QUERY $1"
      fi
      shift
      ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo "Error: query is required" >&2
  usage
fi

# Build command
cmd=(gh search repos "$QUERY" --limit "$LIMIT" --sort "$SORT" --json "$JSON_FIELDS")

[[ -n "$LANGUAGE" ]] && cmd+=(--language "$LANGUAGE")
[[ -n "$TOPIC" ]]    && cmd+=(--topic "$TOPIC")
[[ -n "$STARS" ]]    && cmd+=(--stars "$STARS")
[[ -n "$UPDATED" ]]  && cmd+=(--updated "$UPDATED")

# Run and pass through
"${cmd[@]}"
