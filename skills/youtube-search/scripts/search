#!/usr/bin/env python3
"""
search - Search YouTube via yt-dlp using youtube.com/results URL pattern.

Usage: scripts/search <query> [--limit 10] [--offset 0]
                               [--filter newest|views|rating]
                               [--date hour|today|week|month|year]
                               [--type video|playlist|channel|short|long]
                               [--subtitles-only]
                               [--channel-url URL]
                               [--fields id,title,channel]
                               [--quality-rank]
                               [--pretty]

Examples:
  scripts/search "rust tutorial" --limit 5
  scripts/search "dune trailer" --filter views --type video
  scripts/search "photosynthesis" --subtitles-only --date year
  scripts/search "photosynthesis" --limit 3 --quality-rank
  scripts/search "WebAssembly" --channel-url "https://www.youtube.com/@GoogleChromeDevelopers"
"""
import sys
import json
import subprocess
import time
import argparse
import urllib.parse
import importlib.machinery
import importlib.util
from pathlib import Path

# sp filter codes from references/sp-filters.md
SP_DATE = {
    "hour":  "EgIIAQ%3D%3D",
    "today": "EgIIAg%3D%3D",
    "week":  "EgIIAw%3D%3D",
    "month": "EgIIBA%3D%3D",
    "year":  "EgIIBQ%3D%3D",
}

SP_TYPE = {
    "video":    "EgIQAQ%3D%3D",
    "playlist": "EgIQAw%3D%3D",
    "channel":  "EgIQAg%3D%3D",
    "short":    "EgQQARgB",
    "long":     "EgQQARgC",
}

SP_SORT = {
    "newest": "CAISAhAB",
    "views":  "CAMSAhAB",
    "rating": "CAESAhAB",
}

SP_FEATURE = {
    "subtitles": "EgIoAQ%3D%3D",
}

VALID_CHANNEL_URL_PREFIXES = (
    "https://www.youtube.com/",
    "https://youtube.com/",
    "https://m.youtube.com/",
)


def build_envelope(success, data, meta):
    return {"success": success, "data": data, "meta": meta}


SCRIPT_DIR = Path(__file__).resolve().parent
SCHEMA_VERSION = "0.2.0"
OUTPUT_FIELDS = [
    "id",
    "title",
    "channel",
    "channel_id",
    "duration",
    "view_count",
    "upload_date",
    "url",
    "thumbnail",
    "description_snippet",
]


def build_description_schema():
    return {
        "name": "search",
        "version": SCHEMA_VERSION,
        "flags": [
            {
                "name": "query",
                "type": "string",
                "required": True,
                "default": None,
                "description": "Search query text.",
            },
            {
                "name": "limit",
                "type": "int",
                "required": False,
                "default": 10,
                "description": "Maximum number of results to return.",
            },
            {
                "name": "offset",
                "type": "int",
                "required": False,
                "default": 0,
                "description": "Number of results to skip before returning matches.",
            },
            {
                "name": "filter",
                "type": "choice",
                "required": False,
                "default": None,
                "description": "Sort results by newest, views, or rating.",
            },
            {
                "name": "date",
                "type": "choice",
                "required": False,
                "default": None,
                "description": "Filter results by upload date.",
            },
            {
                "name": "type",
                "type": "choice",
                "required": False,
                "default": None,
                "description": "Filter results by YouTube content type.",
            },
            {
                "name": "subtitles_only",
                "type": "bool",
                "required": False,
                "default": False,
                "description": "Only return results that have subtitles.",
            },
            {
                "name": "channel_url",
                "type": "string",
                "required": False,
                "default": None,
                "description": "Limit search to a specific YouTube channel URL beginning with https://www.youtube.com/, https://youtube.com/, or https://m.youtube.com/.",
            },
            {
                "name": "fields",
                "type": "string",
                "required": False,
                "default": None,
                "description": "Comma-separated output fields to include.",
            },
            {
                "name": "quality_rank",
                "type": "bool",
                "required": False,
                "default": False,
                "description": "Deep-dive and rank extra candidates when limit is at most five.",
            },
            {
                "name": "pretty",
                "type": "bool",
                "required": False,
                "default": False,
                "description": "Pretty-print JSON output.",
            },
            {
                "name": "help_examples",
                "type": "bool",
                "required": False,
                "default": False,
                "description": "Show usage examples and exit.",
            },
            {
                "name": "describe",
                "type": "bool",
                "required": False,
                "default": False,
                "description": "Emit this machine-readable interface schema and exit.",
            },
        ],
        "output_fields": [
            {"name": "id", "type": "string", "description": "YouTube video identifier."},
            {"name": "title", "type": "string", "description": "Video title."},
            {"name": "channel", "type": "string", "description": "Channel display name."},
            {"name": "channel_id", "type": "string", "description": "YouTube channel identifier."},
            {"name": "duration", "type": "int", "description": "Video duration in seconds."},
            {"name": "view_count", "type": "int", "description": "Approximate view count."},
            {"name": "upload_date", "type": "string", "description": "Upload date formatted as YYYY-MM-DD when available."},
            {"name": "url", "type": "string", "description": "Canonical YouTube watch URL."},
            {"name": "thumbnail", "type": "string", "description": "Thumbnail image URL."},
            {"name": "description_snippet", "type": "string", "description": "First 200 characters of the description."},
        ],
    }


def load_score_single_video():
    loader = importlib.machinery.SourceFileLoader("youtube_search_evaluate", str(SCRIPT_DIR / "evaluate"))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    module = importlib.util.module_from_spec(spec)
    previous_bytecode_setting = sys.dont_write_bytecode
    sys.dont_write_bytecode = True
    try:
        loader.exec_module(module)
    finally:
        sys.dont_write_bytecode = previous_bytecode_setting
    return module.score_single_video


score_single_video = load_score_single_video()


def normalize_entry(entry):
    """Extract our schema fields from yt-dlp flat-playlist entry."""
    vid = entry.get("id", "")
    title = entry.get("title", "")
    channel = entry.get("channel") or entry.get("uploader") or ""
    channel_id = entry.get("channel_id") or entry.get("uploader_id") or ""
    duration = entry.get("duration")
    if duration is not None:
        duration = int(duration)
    view_count = entry.get("view_count")
    upload_date = entry.get("upload_date") or ""
    if upload_date and len(upload_date) == 8:
        upload_date = f"{upload_date[:4]}-{upload_date[4:6]}-{upload_date[6:8]}"
    url = entry.get("url") or entry.get("webpage_url") or ""
    if vid and not url:
        url = f"https://www.youtube.com/watch?v={vid}"
    elif url and not url.startswith("http"):
        url = f"https://www.youtube.com/watch?v={vid}"
    thumbnail = entry.get("thumbnail") or entry.get("thumbnails", [{}])[-1].get("url", "") if entry.get("thumbnails") else ""
    if not thumbnail and vid:
        thumbnail = f"https://i.ytimg.com/vi/{vid}/maxresdefault.jpg"
    desc = entry.get("description") or ""
    snippet = desc[:200] if desc else ""

    return {
        "id": vid,
        "title": title,
        "channel": channel,
        "channel_id": channel_id,
        "duration": duration,
        "view_count": view_count,
        "upload_date": upload_date,
        "url": url,
        "thumbnail": thumbnail,
        "description_snippet": snippet,
    }


def filter_fields(record, fields_arg):
    if fields_arg is None:
        return record

    requested = {field.strip() for field in fields_arg.split(",") if field.strip()}
    return {field: record[field] for field in OUTPUT_FIELDS if field in requested and field in record}


def deep_dive(video):
    """Fetch full metadata for a normalized search result."""
    video_ref = video.get("id") or video.get("url")
    if not video_ref:
        return video

    print(f"quality-rank: deep-diving {video_ref}", file=sys.stderr)
    try:
        result = subprocess.run(
            [str(SCRIPT_DIR / "deep-dive"), "--", video_ref],
            capture_output=True,
            text=True,
            timeout=45,
        )
    except subprocess.TimeoutExpired:
        print(f"quality-rank: deep-dive timed out for {video_ref}", file=sys.stderr)
        return video
    if result.returncode != 0 and not result.stdout.strip():
        print(
            f"quality-rank: deep-dive failed for {video_ref}: "
            f"{result.stderr.strip()[:200] or result.returncode}",
            file=sys.stderr,
        )
        return video

    try:
        envelope = json.loads(result.stdout)
    except json.JSONDecodeError:
        print(f"quality-rank: invalid deep-dive JSON for {video_ref}", file=sys.stderr)
        return video

    if not envelope.get("success"):
        error = envelope.get("meta", {}).get("error", "unknown error")
        print(f"quality-rank: deep-dive failed for {video_ref}: {error}", file=sys.stderr)
        return video

    deep_data = envelope.get("data")
    if not isinstance(deep_data, dict):
        return video

    merged = video.copy()
    merged.update(deep_data)
    return merged


def quality_score(video):
    points, max_points, _details = score_single_video(video)
    if max_points == 0:
        return 0, points, max_points
    return points / max_points, points, max_points


def main():
    parser = argparse.ArgumentParser(description="Search YouTube via yt-dlp")
    parser.add_argument("query", nargs="?", help="Search query")
    parser.add_argument("--limit", type=int, default=10, help="Max results (default 10)")
    parser.add_argument("--offset", type=int, default=0, help="Skip first N results (default 0)")
    parser.add_argument("--filter", choices=["newest", "views", "rating"], help="Sort order")
    parser.add_argument("--date", choices=["hour", "today", "week", "month", "year"], help="Upload date filter")
    parser.add_argument("--type", choices=["video", "playlist", "channel", "short", "long"], help="Content type filter")
    parser.add_argument("--subtitles-only", action="store_true", help="Only results with subtitles")
    parser.add_argument("--channel-url", help="Search within a specific YouTube channel URL")
    parser.add_argument("--fields", help="Comma-separated output fields to include")
    parser.add_argument("--quality-rank", action="store_true", help="For limit <= 5, deep-dive extra candidates and rank by quality")
    parser.add_argument("--pretty", action="store_true", help="Pretty-print JSON output")
    parser.add_argument("--help-examples", action="store_true", help="Show usage examples")
    parser.add_argument("--describe", action="store_true", help="Emit machine-readable interface schema and exit")

    args = parser.parse_args()

    if args.describe:
        print(json.dumps(build_description_schema(), indent=2 if args.pretty else None))
        sys.exit(0)

    if not args.query:
        parser.error("the following arguments are required: query")

    if args.help_examples:
        print(__doc__)
        sys.exit(0)

    if args.channel_url and not args.channel_url.startswith(VALID_CHANNEL_URL_PREFIXES):
        envelope = build_envelope(False, [], {
            "source": "yt-dlp",
            "query": args.query,
            "filters": {},
            "error": "--channel-url must start with https://www.youtube.com/, https://youtube.com/, or https://m.youtube.com/",
            "latency_ms": 0
        })
        print(json.dumps(envelope, indent=2 if args.pretty else None))
        sys.exit(1)

    start = time.time()
    encoded_query = urllib.parse.quote(args.query)
    quality_rank = args.quality_rank and args.limit <= 5
    fetch_limit = min(args.limit * 3, 20) if quality_rank else args.limit

    # Build sp parameter
    sp_parts = []
    if args.filter and args.filter in SP_SORT:
        sp_parts.append(SP_SORT[args.filter])
    if args.date and args.date in SP_DATE:
        sp_parts.append(SP_DATE[args.date])
    if args.type and args.type in SP_TYPE:
        sp_parts.append(SP_TYPE[args.type])
    if args.subtitles_only:
        sp_parts.append(SP_FEATURE["subtitles"])

    # Build URL
    if args.channel_url:
        channel_url = args.channel_url.rstrip("/")
        url = f"{channel_url}/search?query={encoded_query}"
    else:
        url = f"https://www.youtube.com/results?search_query={encoded_query}"
        # Use the first sp filter (combining is unreliable)
        if sp_parts:
            url += f"&sp={sp_parts[0]}"

    # Build yt-dlp command
    cmd = [
        "python3", "-m", "yt_dlp",
        url,
        "-J", "--flat-playlist",
        "--extractor-args", "youtubetab:approximate_date",
        "--playlist-start", str(args.offset + 1),
        "--playlist-end", str(args.offset + fetch_limit),
        "--no-warnings",
    ]

    # Rate limiting for bulk requests
    if args.limit > 5:
        cmd += ["--sleep-requests", "1"]

    filters_applied = {}
    if args.filter:
        filters_applied["sort"] = args.filter
    if args.date:
        filters_applied["date"] = args.date
    if args.type:
        filters_applied["type"] = args.type
    if args.subtitles_only:
        filters_applied["subtitles_only"] = True

    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=60)
    except FileNotFoundError:
        latency = int((time.time() - start) * 1000)
        envelope = build_envelope(False, [], {
            "source": "yt-dlp", "query": args.query,
            "filters": filters_applied,
            "error": "python3 not found. Run scripts/check-prereqs.sh to verify dependencies.",
            "latency_ms": latency
        })
        print(json.dumps(envelope, indent=2 if args.pretty else None))
        sys.exit(3)
    except subprocess.TimeoutExpired:
        latency = int((time.time() - start) * 1000)
        envelope = build_envelope(False, [], {
            "source": "yt-dlp", "query": args.query,
            "filters": filters_applied,
            "error": "upstream timeout (60s)", "latency_ms": latency
        })
        print(json.dumps(envelope, indent=2 if args.pretty else None))
        sys.exit(2)

    latency = int((time.time() - start) * 1000)

    if result.returncode != 0 and not result.stdout.strip():
        envelope = build_envelope(False, [], {
            "source": "yt-dlp", "query": args.query,
            "filters": filters_applied,
            "error": result.stderr.strip()[:500] or f"yt-dlp exit code {result.returncode}",
            "latency_ms": latency
        })
        print(json.dumps(envelope, indent=2 if args.pretty else None))
        sys.exit(2)

    # Parse yt-dlp output
    try:
        raw = json.loads(result.stdout)
    except json.JSONDecodeError:
        envelope = build_envelope(False, [], {
            "source": "yt-dlp", "query": args.query,
            "filters": filters_applied,
            "error": "failed to parse yt-dlp JSON output",
            "latency_ms": latency
        })
        print(json.dumps(envelope, indent=2 if args.pretty else None))
        sys.exit(2)

    # Extract entries
    entries = raw.get("entries", []) or []
    data = [normalize_entry(e) for e in entries if e]
    quality_ranked = False

    if quality_rank and data:
        print(
            f"quality-rank: ranking {len(data)} candidates for top {args.limit}",
            file=sys.stderr,
        )
        enriched = []
        for index, video in enumerate(data):
            ranked_video = deep_dive(video)
            score, points, max_points = quality_score(ranked_video)
            enriched.append((score, points, max_points, index, ranked_video))
        enriched.sort(key=lambda item: (item[0], item[1], -item[3]), reverse=True)
        data = [item[4] for item in enriched[:args.limit]]
        quality_ranked = True

    data = [filter_fields(video, args.fields) for video in data]

    total = raw.get("playlist_count") or len(entries)

    meta = {
        "source": "yt-dlp",
        "query": args.query,
        "filters": filters_applied,
        "total": total,
        "offset": args.offset,
        "limit": args.limit,
        "latency_ms": latency
    }
    if quality_ranked:
        meta["quality_ranked"] = True

    envelope = build_envelope(True, data, meta)

    print(json.dumps(envelope, indent=2 if args.pretty else None))


if __name__ == "__main__":
    main()
