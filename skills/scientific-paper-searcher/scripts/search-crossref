#!/bin/bash
# search-crossref — Search CrossRef with journal-article filter and normalized output
# Usage: search-crossref <query> [--year-min YYYY] [--year-max YYYY] [--limit N] [--offset N] [--mailto EMAIL]
set -uo pipefail

# --- Defaults ---
QUERY=""
YEAR_MIN=""
YEAR_MAX=""
LIMIT=20
OFFSET=0
MAILTO="skillmonger@example.com"
FIELDS=""

describe() {
  cat <<'JSON'
{
  "name": "search-crossref",
  "version": "2.0.0",
  "flags": [
    {"name": "query", "type": "string", "required": true, "description": "Search query text"},
    {"name": "--year-min", "type": "integer", "required": false, "description": "Earliest publication year"},
    {"name": "--year-max", "type": "integer", "required": false, "description": "Latest publication year"},
    {"name": "--limit", "type": "integer", "required": false, "default": 20, "description": "Maximum number of results to return"},
    {"name": "--offset", "type": "integer", "required": false, "default": 0, "description": "Zero-based result offset for pagination"},
    {"name": "--mailto", "type": "string", "required": false, "default": "skillmonger@example.com", "description": "Contact email sent to Crossref API"},
    {"name": "--fields", "type": "string", "required": false, "description": "Comma-separated normalized result fields to include"}
  ],
  "output_fields": [
    {"name": "title", "type": "string", "description": "Paper title"},
    {"name": "authors", "type": "array<string>", "description": "Author names"},
    {"name": "year", "type": "integer|null", "description": "Publication year"},
    {"name": "citations", "type": "integer", "description": "Citation count"},
    {"name": "doi", "type": "string|null", "description": "Digital Object Identifier"},
    {"name": "url", "type": "string|null", "description": "Crossref work URL"},
    {"name": "open_access_url", "type": "string|null", "description": "Open access PDF URL when available"},
    {"name": "abstract", "type": "string|null", "description": "Paper abstract with markup removed"},
    {"name": "source_id", "type": "string", "description": "Source-prefixed DOI identifier"},
    {"name": "offset", "type": "integer", "description": "Zero-based result offset used for pagination"}
  ]
}
JSON
}

filter_result_fields() {
  if [[ -z "$FIELDS" ]]; then
    cat
  else
    jq --arg fields "$FIELDS" '
      ($fields | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""))) as $wanted
      | .results |= map(with_entries(select(.key as $key | $wanted | index($key))))
    '
  fi
}

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --describe) describe; exit 0 ;;
    --year-min) YEAR_MIN="$2"; shift 2 ;;
    --year-max) YEAR_MAX="$2"; shift 2 ;;
    --limit) LIMIT="$2"; shift 2 ;;
    --offset) OFFSET="$2"; shift 2 ;;
    --mailto) MAILTO="$2"; shift 2 ;;
    --fields) FIELDS="$2"; shift 2 ;;
    --*) echo '{"error":"unknown_option","detail":"'"$1"'"}'; exit 1 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo '{"error":"missing_query","detail":"Usage: search-crossref <query> [options]"}'
  exit 1
fi

# --- Rate limiting ---
sleep 0.2

# --- Build URL ---
ENCODED_QUERY=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY" 2>/dev/null || echo "$QUERY" | sed 's/ /+/g')

# Always filter to journal articles with abstracts
FILTER="type:journal-article,has-abstract:true"
[[ -n "$YEAR_MIN" ]] && FILTER+=",from-pub-date:${YEAR_MIN}"
[[ -n "$YEAR_MAX" ]] && FILTER+=",until-pub-date:${YEAR_MAX}"

URL="https://api.crossref.org/works?query=${ENCODED_QUERY}&rows=${LIMIT}&offset=${OFFSET}&sort=relevance&order=desc&mailto=${MAILTO}&filter=${FILTER}"

# --- Fetch ---
RESPONSE=$(curl -s --max-time 20 -w "\n%{http_code}" "$URL")
HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [[ "$HTTP_CODE" == "429" ]]; then
  sleep 2
  RESPONSE=$(curl -s --max-time 20 -w "\n%{http_code}" "$URL")
  HTTP_CODE=$(echo "$RESPONSE" | tail -1)
  BODY=$(echo "$RESPONSE" | sed '$d')
fi

if [[ "$HTTP_CODE" != "200" ]]; then
  jq -n --arg query "$QUERY" --arg error "http_${HTTP_CODE}" --argjson offset "$OFFSET" '{
    database: "crossref",
    query: $query,
    total: 0,
    offset: $offset,
    results: [],
    error: $error
  }'
  exit 1
fi

# --- Normalize with jq ---
echo "$BODY" | jq --arg query "$QUERY" --argjson offset "$OFFSET" '{
  database: "crossref",
  query: $query,
  total: (.message["total-results"] // 0),
  offset: $offset,
  results: [(.message.items // [])[] | {
    title: ((.title // [""])[0]),
    authors: [(.author // [])[] | ((.given // "") + " " + (.family // "")) | ltrimstr(" ") | rtrimstr(" ")],
    year: ((.published["date-parts"] // [[null]])[0][0]),
    citations: (.["is-referenced-by-count"] // 0),
    doi: .DOI,
    url: .URL,
    open_access_url: (if .link then (.link[] | select(.["content-type"] == "application/pdf") | .URL) // null else null end),
    abstract: (if .abstract then (.abstract | gsub("<[^>]+>"; "")) else null end),
    source_id: ("DOI:" + .DOI)
  }],
  error: null
}' | filter_result_fields
