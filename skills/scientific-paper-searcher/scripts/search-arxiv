#!/bin/bash
# search-arxiv — Search arXiv Atom API with rate limiting and normalized output
# Usage: search-arxiv <query> [--category CAT] [--limit N] [--offset N] [--sort FIELD]
set -uo pipefail

# --- Defaults ---
QUERY=""
CATEGORY=""
LIMIT=20
OFFSET=0
SORT="submittedDate"
FIELDS=""

describe() {
  cat <<'JSON'
{
  "name": "search-arxiv",
  "version": "2.0.0",
  "flags": [
    {"name": "query", "type": "string", "required": true, "description": "Search query text"},
    {"name": "--category", "type": "string", "required": false, "description": "arXiv category filter"},
    {"name": "--limit", "type": "integer", "required": false, "default": 20, "description": "Maximum number of results to return"},
    {"name": "--offset", "type": "integer", "required": false, "default": 0, "description": "Zero-based result offset for pagination"},
    {"name": "--sort", "type": "string", "required": false, "default": "submittedDate", "description": "arXiv sort field"},
    {"name": "--fields", "type": "string", "required": false, "description": "Comma-separated normalized result fields to include"}
  ],
  "output_fields": [
    {"name": "title", "type": "string", "description": "Paper title"},
    {"name": "authors", "type": "array<string>", "description": "Author names"},
    {"name": "year", "type": "integer|null", "description": "Publication year"},
    {"name": "citations", "type": "null", "description": "arXiv search does not provide citation counts"},
    {"name": "doi", "type": "string|null", "description": "Digital Object Identifier"},
    {"name": "url", "type": "string", "description": "arXiv abstract URL"},
    {"name": "open_access_url", "type": "string|null", "description": "arXiv PDF URL when available"},
    {"name": "abstract", "type": "string", "description": "Paper abstract"},
    {"name": "source_id", "type": "string", "description": "Source-prefixed arXiv identifier"},
    {"name": "offset", "type": "integer", "description": "Zero-based result offset used for pagination"}
  ]
}
JSON
}

filter_result_fields() {
  if [[ -z "$FIELDS" ]]; then
    cat
  else
    jq --arg fields "$FIELDS" '
      ($fields | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""))) as $wanted
      | .results |= map(with_entries(select(.key as $key | $wanted | index($key))))
    '
  fi
}

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --describe) describe; exit 0 ;;
    --category) CATEGORY="$2"; shift 2 ;;
    --limit) LIMIT="$2"; shift 2 ;;
    --offset) OFFSET="$2"; shift 2 ;;
    --sort) SORT="$2"; shift 2 ;;
    --fields) FIELDS="$2"; shift 2 ;;
    --*) echo '{"error":"unknown_option","detail":"'"$1"'"}'; exit 1 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo '{"error":"missing_query","detail":"Usage: search-arxiv <query> [options]"}'
  exit 1
fi

# --- Rate limiting ---
sleep 3

# --- Build URL ---
ENCODED_QUERY=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY" 2>/dev/null || echo "$QUERY" | sed 's/ /+/g')
SEARCH_QUERY="all:${ENCODED_QUERY}"
[[ -n "$CATEGORY" ]] && SEARCH_QUERY="${SEARCH_QUERY}+AND+cat:${CATEGORY}"

URL="https://export.arxiv.org/api/query?search_query=${SEARCH_QUERY}&start=${OFFSET}&max_results=${LIMIT}&sortBy=${SORT}&sortOrder=descending"

# --- Fetch ---
RESPONSE=$(curl -s --max-time 20 -w "\n%{http_code}" "$URL")
HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

if [[ "$HTTP_CODE" != "200" ]]; then
  jq -n --arg query "$QUERY" --arg error "http_${HTTP_CODE}" --argjson offset "$OFFSET" '{
    database: "arxiv",
    query: $query,
    total: 0,
    offset: $offset,
    results: [],
    error: $error
  }'
  exit 1
fi

# --- Parse XML with xmllint and build JSON ---
# Extract total results
TOTAL=$(echo "$BODY" | xmllint --xpath 'string(//*[local-name()="totalResults"])' - 2>/dev/null || echo "0")

# Count entries
ENTRY_COUNT=$(echo "$BODY" | xmllint --xpath 'count(//*[local-name()="entry"])' - 2>/dev/null || echo "0")

if [[ "$ENTRY_COUNT" == "0" || -z "$ENTRY_COUNT" ]]; then
  jq -n --arg query "$QUERY" --argjson offset "$OFFSET" '{
    database: "arxiv",
    query: $query,
    total: 0,
    offset: $offset,
    results: [],
    error: null
  }'
  exit 0
fi

# Extract entries one by one and build JSON array
RESULTS="["
for i in $(seq 1 "$ENTRY_COUNT"); do
  TITLE=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="title"])' - 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g; s/^ *//; s/ *$//')
  ABSTRACT=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="summary"])' - 2>/dev/null | tr '\n' ' ' | sed 's/  */ /g; s/^ *//; s/ *$//')
  PUBLISHED=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="published"])' - 2>/dev/null)
  YEAR=$(echo "$PUBLISHED" | cut -c1-4)
  LINK=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="id"])' - 2>/dev/null)
  PDF_LINK=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="link"][@title="pdf"]/@href)' - 2>/dev/null)
  DOI=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="doi"])' - 2>/dev/null)

  # Extract all authors for this entry
  AUTHOR_COUNT=$(echo "$BODY" | xmllint --xpath 'count((//*[local-name()="entry"])['"$i"']/*[local-name()="author"])' - 2>/dev/null || echo "0")
  AUTHORS="["
  for j in $(seq 1 "$AUTHOR_COUNT"); do
    ANAME=$(echo "$BODY" | xmllint --xpath 'string((//*[local-name()="entry"])['"$i"']/*[local-name()="author"]['"$j"']/*[local-name()="name"])' - 2>/dev/null)
    [[ $j -gt 1 ]] && AUTHORS+=","
    AUTHORS+="$(echo "$ANAME" | jq -Rs '.')"
  done
  AUTHORS+="]"

  # Extract arXiv ID from the link
  ARXIV_ID=$(echo "$LINK" | sed 's|.*/abs/||; s|v[0-9]*$||')

  [[ $i -gt 1 ]] && RESULTS+=","
  RESULTS+=$(jq -n \
    --arg title "$TITLE" \
    --argjson authors "$AUTHORS" \
    --arg year "$YEAR" \
    --arg doi "$DOI" \
    --arg url "$LINK" \
    --arg pdf "$PDF_LINK" \
    --arg abstract "$ABSTRACT" \
    --arg arxiv_id "$ARXIV_ID" \
    '{
      title: $title,
      authors: $authors,
      year: ($year | if . != "" then tonumber else null end),
      citations: null,
      doi: (if $doi != "" then $doi else null end),
      url: $url,
      open_access_url: (if $pdf != "" then $pdf else null end),
      abstract: $abstract,
      source_id: ("ArXiv:" + $arxiv_id)
    }')
done
RESULTS+="]"

jq -n --arg query "$QUERY" --arg total "$TOTAL" --argjson offset "$OFFSET" --argjson results "$RESULTS" '{
  database: "arxiv",
  query: $query,
  total: ($total | tonumber),
  offset: $offset,
  results: $results,
  error: null
}' | filter_result_fields
