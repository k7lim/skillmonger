#!/bin/bash
# check-prereqs - Verify prerequisites for scientific-paper-searcher skill
# Outputs JSON for agent consumption. Exit 0 always - readiness is in the JSON.
set -uo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "${SCRIPT_DIR}/_s2-rate-limit"

checks=()
all_ok=true
semantic_scholar_api_key_configured=false
semantic_scholar_auth_mode="unauthenticated"
semantic_scholar_min_gap_ms=3000

# Check if curl is installed
check_curl() {
  local name="curl"

  if ! command -v curl &>/dev/null; then
    checks+=("{\"name\":\"$name\",\"status\":\"missing\"}")
    all_ok=false
    return
  fi

  local version
  version=$(curl --version 2>&1 | head -1 | awk '{print $2}' || echo "unknown")
  checks+=("{\"name\":\"$name\",\"status\":\"ok\",\"version\":\"$version\"}")
}

# Verify key API endpoints are reachable (also serves as internet check)
check_apis() {
  local available=()
  local missing=()

  # Semantic Scholar (primary database)
  s2_wait
  if curl -s --max-time 5 -o /dev/null -w "%{http_code}" "${S2_AUTH_HEADER[@]+"${S2_AUTH_HEADER[@]}"}" "https://api.semanticscholar.org/graph/v1/paper/search?query=test&limit=1" 2>/dev/null | grep -q "200"; then
    available+=("semantic_scholar")
  else
    missing+=("semantic_scholar")
  fi

  # PubMed E-utilities
  if curl -s --max-time 5 -o /dev/null -w "%{http_code}" "https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&term=test&retmax=1&retmode=json" 2>/dev/null | grep -q "200"; then
    available+=("pubmed")
  else
    missing+=("pubmed")
  fi

  # arXiv API
  if curl -s --max-time 8 -o /dev/null -w "%{http_code}" "https://export.arxiv.org/api/query?search_query=all:test&max_results=1" 2>/dev/null | grep -q "200"; then
    available+=("arxiv")
  else
    missing+=("arxiv")
  fi

  # bioRxiv API
  if curl -s --max-time 5 -o /dev/null -w "%{http_code}" "https://api.biorxiv.org/details/biorxiv/2025-01-01/2025-01-02/0" 2>/dev/null | grep -q "200"; then
    available+=("biorxiv")
    available+=("medrxiv")
  else
    missing+=("biorxiv")
    missing+=("medrxiv")
  fi

  # CrossRef API
  if curl -s --max-time 5 -o /dev/null -w "%{http_code}" "https://api.crossref.org/works?query=test&rows=1" 2>/dev/null | grep -q "200"; then
    available+=("crossref")
  else
    missing+=("crossref")
  fi

  # Build JSON array
  local db_json=""
  for i in "${!available[@]}"; do
    if [ $i -gt 0 ]; then
      db_json+=","
    fi
    db_json+="\"${available[$i]}\""
  done

  local missing_json=""
  for i in "${!missing[@]}"; do
    if [ $i -gt 0 ]; then
      missing_json+=","
    fi
    missing_json+="\"${missing[$i]}\""
  done

  echo "${#available[@]}|$db_json|${#missing[@]}|$missing_json"
}

# Check if jq is installed
check_jq() {
  local name="jq"
  if ! command -v jq &>/dev/null; then
    checks+=("{\"name\":\"$name\",\"status\":\"missing\"}")
    all_ok=false
    return
  fi
  local version
  version=$(jq --version 2>&1 || echo "unknown")
  checks+=("{\"name\":\"$name\",\"status\":\"ok\",\"version\":\"$version\"}")
}

# Check if xmllint is installed
check_xmllint() {
  local name="xmllint"
  if ! command -v xmllint &>/dev/null; then
    checks+=("{\"name\":\"$name\",\"status\":\"missing\"}")
    all_ok=false
    return
  fi
  local version
  version=$(xmllint --version 2>&1 | head -1)
  if [[ -z "$version" ]]; then
    version="unknown"
  fi
  checks+=("{\"name\":\"$name\",\"status\":\"ok\",\"version\":\"$version\"}")
}

check_semantic_scholar_api_key() {
  local name="semantic_scholar_api_key"

  if [[ -n "${SEMANTIC_SCHOLAR_API_KEY:-}" ]]; then
    semantic_scholar_api_key_configured=true
    semantic_scholar_auth_mode="authenticated"
    semantic_scholar_min_gap_ms=1000
    checks+=("{\"name\":\"$name\",\"status\":\"ok\",\"required\":false,\"note\":\"SEMANTIC_SCHOLAR_API_KEY is set; S2 scripts will use authenticated 1 RPS mode\"}")
  else
    checks+=("{\"name\":\"$name\",\"status\":\"missing\",\"required\":false,\"note\":\"Optional; S2 scripts will use unauthenticated shared pool with 3s spacing\"}")
  fi
}

# Run checks
check_curl
check_jq
check_xmllint
check_semantic_scholar_api_key
api_result=$(check_apis)
IFS='|' read -r api_count db_json missing_count missing_json <<< "$api_result"
if [[ "$missing_count" -gt 0 ]]; then
  checks+=("{\"name\":\"api_endpoints\",\"status\":\"missing\",\"available_count\":$api_count,\"missing\":[$missing_json]}")
  all_ok=false
else
  checks+=("{\"name\":\"api_endpoints\",\"status\":\"ok\",\"available_count\":$api_count,\"missing\":[]}")
fi

# Derive internet status from API reachability
if [ -n "$db_json" ]; then
  checks+=("{\"name\":\"internet\",\"status\":\"ok\"}")
else
  checks+=("{\"name\":\"internet\",\"status\":\"unreachable\",\"note\":\"No API endpoints reachable\"}")
  all_ok=false
fi

# Build checks array JSON
checks_json=""
for i in "${!checks[@]}"; do
  if [ $i -gt 0 ]; then
    checks_json+=","
  fi
  checks_json+="${checks[$i]}"
done

# Output JSON result
cat << EOF
{
  "ready": $all_ok,
  "checks": [$checks_json],
  "context": {
    "available_databases": [$db_json],
    "semantic_scholar": {
      "api_key_configured": $semantic_scholar_api_key_configured,
      "auth_mode": "$semantic_scholar_auth_mode",
      "min_gap_ms": $semantic_scholar_min_gap_ms
    }
  }
}
EOF
