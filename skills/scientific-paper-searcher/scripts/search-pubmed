#!/bin/bash
# search-pubmed — Search PubMed via E-utilities with rate limiting and normalized output
# Usage: search-pubmed <query> [--year-min YYYY] [--year-max YYYY] [--limit N] [--offset N] [--reviews-only] [--open-access]
set -uo pipefail

# --- Defaults ---
QUERY=""
YEAR_MIN=""
YEAR_MAX=""
LIMIT=20
OFFSET=0
REVIEWS_ONLY=false
OPEN_ACCESS=false
FIELDS=""

describe() {
  cat <<'JSON'
{
  "name": "search-pubmed",
  "version": "2.0.0",
  "flags": [
    {"name": "query", "type": "string", "required": true, "description": "Search query text"},
    {"name": "--year-min", "type": "integer", "required": false, "description": "Earliest publication year"},
    {"name": "--year-max", "type": "integer", "required": false, "description": "Latest publication year"},
    {"name": "--limit", "type": "integer", "required": false, "default": 20, "description": "Maximum number of results to return"},
    {"name": "--offset", "type": "integer", "required": false, "default": 0, "description": "Zero-based result offset for pagination"},
    {"name": "--reviews-only", "type": "boolean", "required": false, "default": false, "description": "Restrict results to review articles"},
    {"name": "--open-access", "type": "boolean", "required": false, "default": false, "description": "Restrict results to free full text papers"},
    {"name": "--fields", "type": "string", "required": false, "description": "Comma-separated normalized result fields to include"}
  ],
  "output_fields": [
    {"name": "title", "type": "string", "description": "Paper title"},
    {"name": "authors", "type": "array<string>", "description": "Author names"},
    {"name": "year", "type": "string|null", "description": "Publication year"},
    {"name": "citations", "type": "null", "description": "PubMed search does not provide citation counts"},
    {"name": "doi", "type": "string|null", "description": "Digital Object Identifier"},
    {"name": "url", "type": "string", "description": "PubMed paper URL"},
    {"name": "open_access_url", "type": "null", "description": "PubMed search does not provide direct open access URLs"},
    {"name": "abstract", "type": "null", "description": "PubMed summary search does not include abstracts"},
    {"name": "source_id", "type": "string", "description": "Source-prefixed PubMed identifier"},
    {"name": "offset", "type": "integer", "description": "Zero-based result offset used for pagination"}
  ]
}
JSON
}

filter_result_fields() {
  if [[ -z "$FIELDS" ]]; then
    cat
  else
    jq --arg fields "$FIELDS" '
      ($fields | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""))) as $wanted
      | .results |= map(with_entries(select(.key as $key | $wanted | index($key))))
    '
  fi
}

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --describe) describe; exit 0 ;;
    --year-min) YEAR_MIN="$2"; shift 2 ;;
    --year-max) YEAR_MAX="$2"; shift 2 ;;
    --limit) LIMIT="$2"; shift 2 ;;
    --offset) OFFSET="$2"; shift 2 ;;
    --reviews-only) REVIEWS_ONLY=true; shift ;;
    --open-access) OPEN_ACCESS=true; shift ;;
    --fields) FIELDS="$2"; shift 2 ;;
    --*) echo '{"error":"unknown_option","detail":"'"$1"'"}'; exit 1 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo '{"error":"missing_query","detail":"Usage: search-pubmed <query> [options]"}'
  exit 1
fi

# --- Build search term ---
ENCODED_QUERY=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY" 2>/dev/null || echo "$QUERY" | sed 's/ /+/g')
TERM="$ENCODED_QUERY"
[[ "$REVIEWS_ONLY" == true ]] && TERM="${TERM}+AND+review[pt]"
[[ "$OPEN_ACCESS" == true ]] && TERM="${TERM}+AND+free+full+text[filter]"

# --- Build esearch URL ---
ESEARCH_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esearch.fcgi?db=pubmed&term=${TERM}&retmax=${LIMIT}&retstart=${OFFSET}&retmode=json"
[[ -n "$YEAR_MIN" ]] && ESEARCH_URL+="&mindate=${YEAR_MIN}&datetype=pdat"
[[ -n "$YEAR_MAX" ]] && ESEARCH_URL+="&maxdate=${YEAR_MAX}&datetype=pdat"
# datetype needed for both min and max — ensure it's present if either is set
if [[ -n "$YEAR_MIN" && -z "$YEAR_MAX" ]]; then
  ESEARCH_URL+="&maxdate=3000"
elif [[ -z "$YEAR_MIN" && -n "$YEAR_MAX" ]]; then
  ESEARCH_URL+="&mindate=1900&datetype=pdat"
fi

# --- Step 1: esearch ---
RESPONSE=$(curl -s --max-time 15 "$ESEARCH_URL")
PMIDS=$(echo "$RESPONSE" | jq -r '.esearchresult.idlist // [] | join(",")')
TOTAL=$(echo "$RESPONSE" | jq -r '.esearchresult.count // "0"')

if [[ -z "$PMIDS" || "$PMIDS" == "null" ]]; then
  jq -n --arg query "$QUERY" --argjson offset "$OFFSET" '{
    database: "pubmed",
    query: $query,
    total: 0,
    offset: $offset,
    results: [],
    error: null
  }'
  exit 0
fi

# --- 400ms delay between the two calls ---
sleep 0.4

# --- Step 2: esummary ---
ESUMMARY_URL="https://eutils.ncbi.nlm.nih.gov/entrez/eutils/esummary.fcgi?db=pubmed&id=${PMIDS}&retmode=json"
DETAILS=$(curl -s --max-time 15 "$ESUMMARY_URL")

# --- Normalize with jq ---
echo "$DETAILS" | jq --arg query "$QUERY" --arg total "$TOTAL" --argjson offset "$OFFSET" '{
  database: "pubmed",
  query: $query,
  total: ($total | tonumber),
  offset: $offset,
  results: [
    .result | to_entries[] | select(.key != "uids") | .value | {
      title: .title,
      authors: [(.authors // [])[] | .name],
      year: ((.pubdate // "" | split(" ") | .[0]) // null),
      citations: null,
      doi: ((.elocationid // "") | if test("10\\.") then (capture("(?<d>10\\..+)") | .d | rtrimstr(" ")) else null end),
      url: ("https://pubmed.ncbi.nlm.nih.gov/" + .uid + "/"),
      open_access_url: null,
      abstract: null,
      source_id: ("PMID:" + .uid)
    }
  ],
  error: null
}' | filter_result_fields
