#!/bin/bash
# search-s2 — Search Semantic Scholar with rate limiting and normalized output
# Usage: search-s2 <query> [--sort citations|relevance|date] [--year RANGE] [--min-citations N] [--fields-of-study FIELD] [--limit N] [--offset N] [--venue VENUE]
#
# Default: bulk endpoint sorted by citationCount:desc (best for "get a sense of a topic").
# Use --sort relevance for the custom-ranked relevance endpoint when recency/text match matters.
set -uo pipefail

# --- Defaults ---
QUERY=""
YEAR=""
MIN_CITATIONS=""
FIELDS_OF_STUDY=""
LIMIT=20
OFFSET=0
VENUE=""
SORT="citations"
API_FIELDS="title,authors,year,citationCount,abstract,url,externalIds,openAccessPdf"
FIELDS=""
NOTE=""

describe() {
  cat <<'JSON'
{
  "name": "search-s2",
  "version": "2.0.0",
  "flags": [
    {"name": "query", "type": "string", "required": true, "description": "Search query text"},
    {"name": "--sort", "type": "enum", "required": false, "default": "citations", "values": ["citations", "relevance", "date"], "description": "Sort order for Semantic Scholar results"},
    {"name": "--year", "type": "string", "required": false, "description": "Publication year or year range filter"},
    {"name": "--min-citations", "type": "integer", "required": false, "description": "Minimum citation count"},
    {"name": "--fields-of-study", "type": "string", "required": false, "description": "Semantic Scholar fields of study filter"},
    {"name": "--limit", "type": "integer", "required": false, "default": 20, "description": "Maximum number of results to return"},
    {"name": "--offset", "type": "integer", "required": false, "default": 0, "description": "Zero-based result offset for relevance pagination; ignored by Semantic Scholar bulk mode"},
    {"name": "--venue", "type": "string", "required": false, "description": "Publication venue filter"},
    {"name": "--fields", "type": "string", "required": false, "description": "Comma-separated normalized result fields to include"}
  ],
  "output_fields": [
    {"name": "title", "type": "string", "description": "Paper title"},
    {"name": "authors", "type": "array<string>", "description": "Author names"},
    {"name": "year", "type": "integer|null", "description": "Publication year"},
    {"name": "citations", "type": "integer", "description": "Citation count"},
    {"name": "doi", "type": "string|null", "description": "Digital Object Identifier"},
    {"name": "url", "type": "string|null", "description": "Semantic Scholar paper URL"},
    {"name": "open_access_url", "type": "string|null", "description": "Open access PDF URL when available"},
    {"name": "abstract", "type": "string|null", "description": "Paper abstract"},
    {"name": "source_id", "type": "string", "description": "Source-prefixed Semantic Scholar paper identifier"},
    {"name": "offset", "type": "integer", "description": "Zero-based result offset used for pagination"},
    {"name": "note", "type": "string|null", "description": "Pagination note when offset is ignored by Semantic Scholar bulk mode"}
  ]
}
JSON
}

filter_result_fields() {
  if [[ -z "$FIELDS" ]]; then
    cat
  else
    jq --arg fields "$FIELDS" '
      ($fields | split(",") | map(gsub("^\\s+|\\s+$"; "")) | map(select(. != ""))) as $wanted
      | .results |= map(with_entries(select(.key as $key | $wanted | index($key))))
    '
  fi
}

# --- Parse args ---
while [[ $# -gt 0 ]]; do
  case "$1" in
    --describe) describe; exit 0 ;;
    --year) YEAR="$2"; shift 2 ;;
    --min-citations) MIN_CITATIONS="$2"; shift 2 ;;
    --fields-of-study) FIELDS_OF_STUDY="$2"; shift 2 ;;
    --limit) LIMIT="$2"; shift 2 ;;
    --offset) OFFSET="$2"; shift 2 ;;
    --venue) VENUE="$2"; shift 2 ;;
    --sort) SORT="$2"; shift 2 ;;
    --fields) FIELDS="$2"; shift 2 ;;
    --*) echo '{"error":"unknown_option","detail":"'"$1"'"}'; exit 1 ;;
    *) QUERY="$1"; shift ;;
  esac
done

if [[ -z "$QUERY" ]]; then
  echo '{"error":"missing_query","detail":"Usage: search-s2 <query> [--sort citations|relevance|date] [options]"}'
  exit 1
fi

# --- Rate limiting (global, shared across all S2 scripts) ---
source "$(dirname "$0")/_s2-rate-limit"

# --- Build URL ---
ENCODED_QUERY=$(python3 -c "import urllib.parse, sys; print(urllib.parse.quote(sys.argv[1]))" "$QUERY" 2>/dev/null || echo "$QUERY" | sed 's/ /+/g')

case "$SORT" in
  relevance)
    # Relevance endpoint — custom ranker, supports limit
    URL="https://api.semanticscholar.org/graph/v1/paper/search?query=${ENCODED_QUERY}&fields=${API_FIELDS}&limit=${LIMIT}"
    [[ "$OFFSET" -gt 0 ]] && URL+="&offset=${OFFSET}"
    ;;
  citations|citationCount)
    URL="https://api.semanticscholar.org/graph/v1/paper/search/bulk?query=${ENCODED_QUERY}&fields=${API_FIELDS}&sort=citationCount:desc"
    [[ "$OFFSET" -gt 0 ]] && NOTE="offset ignored for Semantic Scholar bulk endpoint; use --sort relevance for offset pagination"
    ;;
  date|publicationDate)
    URL="https://api.semanticscholar.org/graph/v1/paper/search/bulk?query=${ENCODED_QUERY}&fields=${API_FIELDS}&sort=publicationDate:desc"
    [[ "$OFFSET" -gt 0 ]] && NOTE="offset ignored for Semantic Scholar bulk endpoint; use --sort relevance for offset pagination"
    ;;
  *)
    echo '{"error":"invalid_sort","detail":"Valid: citations (default), relevance, date"}'
    exit 1
    ;;
esac

[[ -n "$YEAR" ]] && URL+="&year=${YEAR}"
[[ -n "$MIN_CITATIONS" ]] && URL+="&minCitationCount=${MIN_CITATIONS}"
[[ -n "$FIELDS_OF_STUDY" ]] && URL+="&fieldsOfStudy=${FIELDS_OF_STUDY}"
[[ -n "$VENUE" ]] && URL+="&venue=${VENUE}"

# --- Fetch ---
fetch() {
  curl -s -w "\n%{http_code}" --max-time 15 "${S2_AUTH_HEADER[@]+"${S2_AUTH_HEADER[@]}"}" "$URL"
}

s2_wait
RESPONSE=$(fetch)
HTTP_CODE=$(echo "$RESPONSE" | tail -1)
BODY=$(echo "$RESPONSE" | sed '$d')

# --- Handle 429 ---
if [[ "$HTTP_CODE" == "429" ]]; then
  sleep 30
  s2_wait
  RESPONSE=$(fetch)
  HTTP_CODE=$(echo "$RESPONSE" | tail -1)
  BODY=$(echo "$RESPONSE" | sed '$d')
fi

if [[ "$HTTP_CODE" != "200" ]]; then
  jq -n --arg query "$QUERY" --arg error "http_${HTTP_CODE}" --arg note "$NOTE" --argjson offset "$OFFSET" '{
    database: "semantic_scholar",
    query: $query,
    total: 0,
    offset: $offset,
    results: [],
    error: $error
  } + (if $note != "" then {note: $note} else {} end)'
  exit 1
fi

# --- Normalize with jq ---
# Bulk endpoint returns up to 1000/page with no `limit` param, so we truncate client-side.
echo "$BODY" | jq --arg query "$QUERY" --arg note "$NOTE" --argjson limit "$LIMIT" --argjson offset "$OFFSET" '{
  database: "semantic_scholar",
  query: $query,
  total: (.total // 0),
  offset: $offset,
  results: [((.data // [])[:$limit])[] | {
    title: .title,
    authors: [(.authors // [])[] | .name],
    year: .year,
    citations: (.citationCount // 0),
    doi: (.externalIds.DOI // null),
    url: .url,
    open_access_url: (.openAccessPdf.url // null),
    abstract: .abstract,
    source_id: ("S2:" + (.paperId // "unknown"))
  }],
  error: null
} + (if $note != "" then {note: $note} else {} end)' | filter_result_fields
